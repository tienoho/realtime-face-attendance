# Flask Configuration
SECRET_KEY=your-super-secret-key-change-in-production
FLASK_ENV=development
FLASK_DEBUG=0

# Database Configuration
# Set DB_TYPE to 'postgresql' (RECOMMENDED)
DB_TYPE=postgresql

# PostgreSQL Configuration (when DB_TYPE=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_USER=faceuser
DB_PASSWORD=your-database-password
DB_NAME=face_attendance

# MySQL Configuration (when DB_TYPE=mysql) - DEPRECATED
# DB_TYPE=mysql
# DB_USER=root

# API Configuration
API_PORT=5001
